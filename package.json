{
  "name": "gin",
  "version": "3.1.0",
  "description": "Frontend build tools",
  "scripts": {
    "start": "npm run dev",
    "dev": "webpack --progress --config  webpack.config.dev.js --watch",
    "build": "webpack --progress --config webpack.config.build.js",
    "lint": "lint-staged",
    "lint-all": "eslint \"src/**/*.js\" --fix && csscomb src --tty-mode",
    "pre-commit": "lint-staged"
  },
  "email": "hello@saschaeggenberger.com",
  "author": "Sascha Eggenberger",
  "license": "MIT",
  "homepage": "https://sascha.is",
  "keywords": [
    "drupal",
    "webpack",
    "gin",
    "frontend"
  ],
  "devDependencies": {
    "@babel/cli": "^7.10.1",
    "@babel/core": "^7.13.8",
    "@babel/plugin-syntax-dynamic-import": "7.0.0",
    "@babel/preset-env": "^7.13.9",
    "autoprefixer": "^9.7.3",
    "babel-eslint": "10.0.1",
    "babel-loader": "^8.2.2",
    "babel-plugin-drupal-behaviors": "^0.1.1",
    "breakpoint-sass": "^2.7.1",
    "clean-webpack-plugin": "^3.0.0",
    "css-loader": "^3.4.1",
    "csscomb": "4.3.0",
    "dotenv-webpack": "^7.0.1",
    "es6-promise": "^4.1.1",
    "eslint": "6.8.0",
    "eslint-config-prettier": "^6.10.0",
    "eslint-import-resolver-webpack": "0.13.0",
    "eslint-plugin-import": "2.19.1",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-prettier": "^3.1.2",
    "eslint-plugin-react": "^7.19.0",
    "expose-loader": "^2.0.0",
    "fibers": "^5.0.0",
    "file-loader": "^5.0.2",
    "img-loader": "^3.0.2",
    "lint-staged": "9.5.0",
    "mini-css-extract-plugin": "^0.11.3",
    "node-sass-glob-importer": "^5.3.2",
    "postcss-loader": "^3.0.0",
    "raw-loader": "^4.0.2",
    "sass-loader": "^11.0.1",
    "sass-resources-loader": "^2.0.3",
    "svg-inline-loader": "^0.8.0",
    "svg-spritemap-webpack-plugin": "^3.9.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.26.3",
    "webpack-cli": "^4.5.0",
    "webpack-dev-middleware": "^4.1.0",
    "webpack-merge": "^5.7.3",
    "webpack-notifier": "^1.13.0",
    "webpack-remove-empty-scripts": "^0.7.1"
  },
  "dependencies": {
    "core-js": "^2.6.11",
    "mdn-polyfills": "^5.19.0",
    "modernizr": "^3.8.0",
    "normalize.css": "^8.0.0",
    "sass": "^1.26.2"
  },
  "lint-staged": {
    "*.scss": [
      "csscomb --tty-mode",
      "git add"
    ],
    "*.js": [
      "eslint --fix \"{,**,**/**}*.js\"",
      "git add"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git.drupalcode.org/project/gin"
  },
  "browserslist": [
    "last 2 versions",
    "> 1%",
    "ie > 11",
    "iOS > 9"
  ]
}
